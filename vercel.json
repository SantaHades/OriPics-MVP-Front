{
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/renew-credits",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/charge-subscriptions",
      "schedule": "0 1 * * *"
    }
  ],
  "ignoreCommand": "case \"$VERCEL_GIT_COMMIT_REF\" in dependabot/*) exit 0;; *) exit 1;; esac"
}
